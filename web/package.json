{
  "name": "rubble-web-demos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run wasm",
    "dev": "vite",
    "wasm": "wasm-pack build ../crates/rubble-wasm --target web --out-dir ../../web/src/wasm",
    "prebuild": "npm run wasm",
    "build": "tsc && vite build",
    "build:all": "npm run wasm && npm run build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "playwright:install": "playwright install chromium",
    "pretest": "npm run wasm",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:webgpu": "playwright test tests/webgpu-narrowphase.spec.ts tests/ground-contact.spec.ts",
    "test:smoke": "npm run build && playwright test tests/ground-contact.spec.ts",
    "bench:10k": "npm run build && playwright test tests/bench-10k-webgpu.spec.ts --reporter=list"
  },
  "dependencies": {
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.172.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.0",
    "wasm-pack": "^0.14.0"
  }
}
